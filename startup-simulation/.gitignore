.vercel

# TypeScript-Build-Cache (wird bei jedem tsc-Lauf neu geschrieben)
tsconfig.tsbuildinfo

# Generierte Spielinhalte — werden von scripts/generate-content.mjs erzeugt
src/lib/gameContent.generated.ts

# Einmal-Migrations-Snapshot (lokal, nicht committen)
scripts/.content-snapshot.json

# Graphify Wissens-Graph (lokal, wird per `graphify update startup-simulation/src` neu generiert)
src/graphify-out/

# Temp-Ordner des Determinismus-Checks (scripts/check-determinism.mjs)
.tmp-check/

# Temp-Ordner des Simulations-Scripts (scripts/simulate.mjs)
.tmp-sim/
